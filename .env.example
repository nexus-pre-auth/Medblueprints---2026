# MedBlueprints Environment Configuration
# Copy this to .env and fill in your values before deploying.

# ── Anthropic Claude API (REQUIRED) ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-6

# ── Database ──────────────────────────────────────────────────────────────
# Local dev (SQLite — zero config):
DATABASE_URL=sqlite+aiosqlite:///./medblueprints.db
# Production (PostgreSQL — set this in docker-compose.prod.yml env):
# DATABASE_URL=postgresql+asyncpg://medblueprints:POSTGRES_PASSWORD@db:5432/medblueprints

# ── PostgreSQL (production docker-compose only) ───────────────────────────
# Used by docker-compose.prod.yml to create the postgres container.
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis (production docker-compose only) ────────────────────────────────
# Leave blank for no password (fine on private internal network).
# Set a password if Redis port is ever exposed.
REDIS_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for local dev.
# Production: set to your actual frontend domain.
CORS_ORIGINS=*
# Example for production:
# CORS_ORIGINS=https://medblueprints.com,https://www.medblueprints.com

# ── Neo4j Graph Database (optional) ──────────────────────────────────────
# Falls back to in-memory NetworkX if not enabled.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
USE_NEO4J=false

# ── Vector Search ─────────────────────────────────────────────────────────
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/regulatory_index.faiss

# ── Approval Prediction Model ─────────────────────────────────────────────
MODEL_PATH=./data/approval_model.joblib

# ── AR Visualization ──────────────────────────────────────────────────────
AR_OUTPUT_PATH=./data/ar_outputs
WEBXR_BASE_URL=http://localhost:8000/ar

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── API Key Authentication ────────────────────────────────────────────────
# Set REQUIRE_API_KEY=true to enforce API key auth in production
REQUIRE_API_KEY=false
# Default demo key for local testing (change in production!)
DEMO_API_KEY=demo-medblueprints-2026
# Additional comma-separated keys for multiple architects
API_KEYS=

# ── Frontend ──────────────────────────────────────────────────────────────
# URL of the backend API (used by Next.js frontend at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000
